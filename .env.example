# Database Configuration
TURSO_DATABASE_URL=your_turso_database_url_here
TURSO_AUTH_TOKEN=your_turso_auth_token_here

# Application Settings
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Lubao Community Share Hub"

# Email Server Configuration (SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_USER=your_email_here@gmail.com
EMAIL_PASS=your_gmail_app_password_here
EMAIL_FROM="Lubao Share Hub <your_email_here@gmail.com>"

# File Upload Settings
# Max file size in bytes (default 5 MB)
MAX_UPLOAD_SIZE=5242880
