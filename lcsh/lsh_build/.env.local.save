
# Start dev server
npm run dev# ============================================================
# Lubao Community Share Hub – Environment Variables
# Copy this file to .env.local and fill in your values.
# ============================================================

# --- Turso Database ---
# Get these from: https://app.turso.tech/
TURSO_DATABASE_URL=libsql://your-db-name-yourname.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token-here

# --- JWT Secret (generate a 64-char random string) ---
# Use: openssl rand -base64 64
JWT_SECRET=change-this-to-a-random-64-character-secret-string-for-production

# --- App Config ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Lubao Community Share Hub"

# --- Email (Gmail SMTP) ---
# Create an App Password at: https://myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_USER=lubaocommunitysharehub@gmail.com
EMAIL_PASS=your-16-char-app-password
EMAIL_FROM="Lubao Share Hub <lubaocommunitysharehub@gmail.com>"

# --- File Upload ---
# Max file size in bytes (default 5 MB)
MAX_UPLOAD_SIZE=5242880
